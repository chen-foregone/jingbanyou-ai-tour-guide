# 数据库配置
DB_URL=jdbc:mysql://localhost:3306/jingbanyou?useUnicode=true&characterEncoding=utf8&zeroDateTimeBehavior=convertToNull&useSSL=true&serverTimezone=GMT%2B8
DB_USERNAME=root
DB_PASSWORD=

# 阿里云 DashScope API Key（AI 对话）
DASHSCOPE_API_KEY=your-dashscope-api-key

# 阿里云 OSS 配置（文件上传）
OSS_ACCESS_KEY=your-oss-access-key
OSS_SECRET_KEY=your-oss-secret-key
OSS_BUCKET_NAME=your-bucket-name
OSS_DOMAIN=https://your-bucket-name.oss-cn-beijing.aliyuncs.com

# RabbitMQ 配置
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=admin
RABBITMQ_VHOST=/

# 高德地图 API Key（MCP Server）
AMAP_API_KEY=your-amap-api-key

# Druid 监控台
DRUID_USERNAME=ruoyi
DRUID_PASSWORD=
