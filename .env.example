# 数据库配置
DB_URL=jdbc:mysql://localhost:3306/jingbanyou?useUnicode=true&characterEncoding=utf8&zeroDateTimeBehavior=convertToNull&useSSL=true&serverTimezone=GMT%2B8
DB_USERNAME=root
DB_PASSWORD=your_db_password

# JWT 密钥（建议 32 位以上随机字符串）
JWT_SECRET=your_strong_jwt_secret_here

# 阿里云 DashScope API Key（用于 AI 对话功能）
DASHSCOPE_API_KEY=your_dashscope_api_key

# 阿里云 OSS 配置（用于文件上传）
ALIYUN_OSS_ACCESS_KEY=your_oss_access_key
ALIYUN_OSS_SECRET_KEY=your_oss_secret_key

# Druid 监控台密码
DRUID_USERNAME=ruoyi
DRUID_PASSWORD=your_druid_password
